rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles
    match /users/{userId} {
      // Users can read/write their own profile
      // Guardians can read profiles of users they are linked to
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.uid in resource.data.guardians);
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Alerts Subcollection (inside users)
      match /alerts/{alertId} {
        // User can create alerts for themselves
        // Guardians can read alerts of their linked user
        allow read: if request.auth != null && (request.auth.uid == userId || request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.guardians);
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Pairing Codes (10 min TTL handled by Cloud Functions or client-side checks)
    match /pairing_codes/{code} {
      // Anyone authenticated can create a code
      allow create: if request.auth != null;
      // Anyone authenticated can read a code to link accounts
      allow read: if request.auth != null;
      // Only creator can delete it, or backend cleanup
      allow delete: if request.auth != null && request.auth.uid == resource.data.creator_uid;
    }
  }
}
